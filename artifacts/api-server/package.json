{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development TZ=America/Sao_Paulo tsx --env-file=../../.env ./src/index.ts",
    "build": "tsx ./build.ts",
    "start": "cd ../../lib/db && drizzle-kit push --force --config ./drizzle.config.ts && cd ../../artifacts/api-server && node dist/index.cjs",
    "start-only": "cross-env TZ=America/Sao_Paulo node dist/index.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@workspace/db": "workspace:*",
    "@workspace/api-zod": "workspace:*",
    "drizzle-orm": "catalog:",
    "drizzle-kit": "^0.31.9",
    "express": "^5",
    "cookie-parser": "^1.4.7",
    "cors": "^2"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/express": "^5.0.6",
    "@types/cors": "^2.8.19",
    "@types/cookie-parser": "^1.4.10",
    "esbuild": "^0.27.3",
    "tsx": "catalog:"
  }
}